# =============================================================================
# UI Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values

# Merchant API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=your-api-key

# PSP (Payment Service Provider) Configuration
NEXT_PUBLIC_PSP_URL=http://localhost:8001
NEXT_PUBLIC_PSP_API_KEY=psp-api-key-12345

# API Version
NEXT_PUBLIC_API_VERSION=2026-01-16

# Post-Purchase Agent Configuration (server-side, no NEXT_PUBLIC_ prefix)
POST_PURCHASE_AGENT_URL=http://localhost:8003

# Webhook Configuration
# Secret for validating incoming webhooks from the merchant
WEBHOOK_SECRET=whsec_demo_secret
